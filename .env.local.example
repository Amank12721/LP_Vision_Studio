# Google Cloud Vertex AI Configuration
# Add these secrets in Supabase Dashboard > Project Settings > Edge Functions > Secrets

GCP_PROJECT_ID=your-project-id-here
GCP_LOCATION=us-central1
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# GROQ API for scene generation
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Flask API URL (set this to your deployed backend URL)
VITE_FLASK_API_URL=https://your-backend-url.onrender.com
